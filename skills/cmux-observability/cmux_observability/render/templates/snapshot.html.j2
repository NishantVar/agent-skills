<!doctype html>
<html lang="en"><head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="color-scheme" content="light dark">
<title>cmux observability — {{ snapshot.captured_at.isoformat() }}</title>
<style>
  /* T7: theme tokens — light defaults, dark via prefers-color-scheme.
     Drives the dashboard's chrome; state tokens are consumed by chips/badges. */
  :root {
    color-scheme: light dark;

    /* Font stacks */
    --font-sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;

    /* Surface + text tokens (light) */
    --bg: #ffffff;
    --surface: #f6f7f9;
    --text: #15181d;
    --muted: #6b7280;
    --border: #dfe3ea;

    /* Spacing scale (4-pt grid) */
    --space-1: 4px;
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;

    /* Radii */
    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-pill: 999px;

    /* Contrast helper */
    --contrast-strong: #000000;

    /* State tokens */
    --state-running: #1d7a3a;          /* green */
    --state-needs-input: #b1601e;      /* amber */
    --state-idle: #6b7280;             /* muted gray */
    --state-unknown: #9aa3ad;          /* dotted gray, paired with dotted border */
    --state-unknown-border-style: dotted;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f1115;
      --surface: #181b22;
      --text: #e6e8ec;
      --muted: #8a8f99;
      --border: #2a2f38;
      --contrast-strong: #ffffff;

      --state-running: #4fc279;
      --state-needs-input: #d2a247;
      --state-idle: #8a8f99;
      --state-unknown: #6e7682;
    }
  }

  /* T7: respect users who opt out of motion. */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
<style>{{ inline_css | safe }}</style>
</head><body>
<header>
  <h1>cmux observability</h1>
  <div class="meta">
    snapshot {{ snapshot.captured_at.isoformat() }} ·
    host {{ snapshot.host }} ·
    cmux {{ snapshot.cmux_version or "unavailable" }}
  </div>
</header>
<main>
  {% if snapshot.failures %}{% include "_failures.html.j2" %}{% endif %}

  <section>
    <h2>Counters</h2>
    <p>
      <span class="chip">agents: <b>{{ snapshot.agents | length }}</b></span>
      <span class="chip state-running">running: <b>{{ snapshot.agents | selectattr("state","equalto","running") | list | length }}</b></span>
      <span class="chip state-needs_input">needs input: <b>{{ snapshot.agents | selectattr("state","equalto","needs_input") | list | length }}</b></span>
      <span class="chip">workspaces: <b>{{ snapshot.workspaces | length }}</b></span>
      <span class="chip">surfaces: <b>{{ snapshot.workspaces | map(attribute="surfaces") | map("length") | sum }}</b></span>
    </p>
  </section>

  {% if snapshot.workspaces %}
    <section><h2>Workspaces</h2>
      {% for ws in snapshot.workspaces %}{% include "_workspace.html.j2" %}{% endfor %}
    </section>
  {% else %}
    <section><h2>Workspaces</h2><p>No agents detected.</p></section>
  {% endif %}

  {% if snapshot.themes %}
    {% include "_themes.html.j2" %}
  {% endif %}

  {% if snapshot.productivity %}
    {% include "_productivity.html.j2" %}
  {% endif %}

  {% if snapshot.history %}
    {% include "_history.html.j2" %}
  {% endif %}
</main>
<script>{{ inline_js | safe }}</script>
</body></html>
