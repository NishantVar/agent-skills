{# T12: workspace card. Header shows title (basename + muted full path when
   the title looks like a filesystem path), an activity dot whose color encodes
   the highest-priority surface state in the workspace, and a surface count.
   Body is wrapped in <details>, `open` when any surface is needs_input or
   running. #}
{%- set _ws_agents = snapshot.agents | selectattr("workspace_ref","equalto",ws.ref) | list -%}
{%- set _has_needs_input = _ws_agents | selectattr("state","equalto","needs_input") | list | length > 0 -%}
{%- set _has_running = _ws_agents | selectattr("state","equalto","running") | list | length > 0 -%}
{%- set _has_idle = _ws_agents | selectattr("state","equalto","idle") | list | length > 0 -%}
{%- if _has_needs_input -%}
  {%- set _activity = "needs_input" -%}
{%- elif _has_running -%}
  {%- set _activity = "running" -%}
{%- elif _has_idle -%}
  {%- set _activity = "idle" -%}
{%- else -%}
  {%- set _activity = "unknown" -%}
{%- endif -%}
{%- set _title = ws.title or "" -%}
{%- set _is_path = _title.startswith("/") or "/" in _title -%}
{%- if _is_path -%}
  {%- set _basename = _title.rstrip("/").rsplit("/", 1)[-1] or _title -%}
{%- endif -%}
<div class="card">
  <header class="card-header">
    <h3 class="card-title">
      <span class="chip">{{ ws.ref }}</span>
      {% if _is_path %}
        <span class="ws-title-basename">{{ _basename }}</span>
        <span class="ws-path-full">{{ _title }}</span>
      {% else %}
        <span class="ws-title-basename">{{ _title }}</span>
      {% endif %}
    </h3>
    <span class="activity-dot" data-activity="{{ _activity }}" aria-label="activity: {{ _activity }}"></span>
    <span class="surface-count" title="surface count">{{ ws.surfaces | length }}</span>
  </header>
  <details class="card-body"{% if _has_needs_input or _has_running %} open{% endif %}>
    <summary>surfaces ({{ ws.surfaces | length }})</summary>
    <table>
      <thead><tr><th>surface</th><th>title</th><th>state</th><th>summary</th><th>cpu</th><th>mem</th></tr></thead>
      <tbody>
        {% for s in ws.surfaces %}
          {% set agent = snapshot.agents | selectattr("surface_ref","equalto",s.ref) | list | first %}
          {% include "_agent_row.html.j2" %}
        {% endfor %}
      </tbody>
    </table>
  </details>
</div>
