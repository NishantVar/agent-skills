{# T13: surface row redesign — flex layout, state pill, mono title,
   CSS-truncated summary with full text in title=, captured relative time,
   and a copy-ref chip. Row root is <div class="surface-row"> (replacing the
   prior <tr>) so the flex layout works without abusing table internals.

   Filter contract (T9 + T10) preserved on the row root:
     data-state="<state>"   — state-bucket filter
     data-search="<corpus>" — substring filter; lowercased once at render

   Identifier-strip (T20): the literal `surface:N` token appears ONLY inside
   the copy-ref chip (body + title attribute). #}
{%- set _corpus_parts = [ws.title or "", s.title or ""] -%}
{%- if agent and agent.summary and agent.summary.text -%}
  {%- set _corpus_parts = _corpus_parts + [agent.summary.text] -%}
{%- endif -%}
{%- set _search_corpus = (_corpus_parts | join(" ")) | lower -%}
<div class="surface-row" data-search="{{ _search_corpus }}"{% if agent %} data-state="{{ agent.state }}"{% endif %}>
  {% if agent %}
    <span class="state-pill state-{{ agent.state }}">{{ agent.state }}</span>
  {% else %}
    <span class="state-pill state-unknown">{{ s.kind }}</span>
  {% endif %}
  <span class="mono-title">{{ s.title }}</span>
  {% if agent and agent.summary %}
    <span class="surface-summary" title="{{ agent.summary.text }}">{{ agent.summary.text | truncated_summary }}</span>
  {% elif not agent %}
    <span class="surface-summary">(not classified as an agent)</span>
  {% else %}
    {# T13 step 5 deviation: the model exposes no `no_summarize` signal, so
       the (skipped) vs (no screen access) distinction collapses into the
       catch-all (no screen access). #}
    <span class="surface-summary">(no screen access)</span>
  {% endif %}
  {% if agent and agent.summary and agent.summary.cached_at %}
    <span class="surface-captured">captured {{ agent.summary.cached_at | relative_time }}</span>
  {% else %}
    <span class="surface-captured"></span>
  {% endif %}
  <span class="chip surface-copy-ref" title="cmux focus {{ s.ref }}">{{ s.ref }}</span>
</div>
