skill p2p(my_title = "" <"Optional snake_case title to register under on first use. If empty AND the current cmux tab title is generic (`claude`, `codex`, etc.), the helper returns info_needed; pick a title that reflects this agent's role and rerun. Do NOT ask the human — choose from your own role context. Title is sticky for the agent's lifetime.">, peer = "" <"Cmux tab title of the destination peer. Single routing key, scoped to the caller's workspace by default.">, message = "" <"Message body. Always passed via --message-file to side-step shell quoting.">)
    description: "P2P messaging between cmux agents: one verb (`send`) handles first contact, follow-up, and reply. Routes by cmux tab title scoped to the caller's workspace; returns a handoff JSON object when a peer must be spawned or another skill must run."

    require single_stable_title
    require always_use_send_verb
    require honor_handoff_json
    avoid skill_calls_skill

    flow:
        if inline_bootstrap_present.applies()
            reply_to_inline_bootstrap()
        else
            send_via_helper()

        if handoff_received.applies()
            follow_handoff_instruction()


block send_via_helper()
    description: "Issue one `send` call. The helper handles registration, title resolution, plain-vs-bootstrap framing, cross-workspace routing, and payload-file generation."
    flow:
        "Write {message} to a temp file like `/tmp/p2p-out-{peer}.txt`."
        "Run `python3 ~/.claude/skills/p2p/agent_msg.py send --peer {peer} --message-file <path>`. Include `--my-title {my_title}` only on the first invocation in this agent's lifetime; the helper ignores it once a manifest exists. Add `--one-way` for fire-and-forget delivery — the wire frame becomes `[from: <me> | one-way] <body>` and any first-contact bootstrap drops the reply request. Add `--workspace <ref>` to scope the title match to a different workspace, or `--workspace all` for global scope."
        "Parse the JSON on stdout. `{ok: true}` is done. `{ok: false}` carries `code`, `agent_instruction`, and (per code) extra fields like `payload_file` or `candidates`."


block reply_to_inline_bootstrap()
    description: "An inbound `[p2p-bootstrap]` block is in this agent's prompt. Do one `send` call — register + reply in the same invocation."
    flow:
        "Read `peer_title=` / `peer_surface=` / `suggested_title=` from the inline `[p2p-bootstrap]` block in the user-turn prompt."
        "Write the reply body to a temp file like `/tmp/p2p-out-{peer}.txt`."
        "Run `python3 ~/.claude/skills/p2p/agent_msg.py send --peer <peer_title> --peer-surface <peer_surface> --bootstrap-suggested-title <suggested_title> --message-file <path>`. The helper registers this agent under `suggested_title` on the fly and routes directly without title resolution."
        "If the bootstrap text is in a file rather than inline, pass `--bootstrap-file <path>` instead — it fills --peer, --peer-surface, and --bootstrap-suggested-title from the parsed text."


block follow_handoff_instruction()
    description: "The helper returned ok:false. Read `agent_instruction` and act."
    flow:
        "`peer_unknown` → invoke the tfork skill and have it spawn an agent whose first user-turn input is the contents of `payload_file`. Use whatever delayed-input mechanism tfork currently exposes — p2p does not prescribe a flag. The payload file is already written 0600; do not re-create it."
        "`peer_ambiguous` → rerun with --peer set + --peer-surface <candidates[i].ref> to route by surface directly, or with --workspace <ref> to scope the title match. A bare `surface:N` string is not a valid --peer."
        "`info_needed` with `missing: [\"self_title\"]` → choose a snake_case title that reflects this agent's role (e.g., `reviewer`, `qa_lead`, `builder`) from your own context, then rerun with `--my-title <t>`. Do NOT ask the human."
        "`title_collision` → another live agent in the workspace already holds that title. Pick a different --my-title and rerun."
        "`empty_message` → write a non-empty body and rerun."


const single_stable_title = """Pick one short, lowercase, snake_case title on the first call and keep it for life. Peers route by `(workspace, title)`; renaming mid-session makes this agent unreachable under the prior title. The helper renames the cmux tab cosmetically to match the registered title."""

const always_use_send_verb = """All outgoing messages go through `agent_msg.py send`. Never call `cmux set-buffer`, `cmux paste-buffer`, or `cmux send-key` directly — the helper alone passes `--workspace` (without it cross-workspace delivery fails as `Surface is not a terminal`), applies the `[from: <me>]` prefix, and uses a per-op buffer name to avoid concurrent-sender interleaving."""

const honor_handoff_json = """When the helper returns `ok: false`, the JSON contains an explicit `agent_instruction` field. Follow it verbatim — do not improvise around it. The handoff carries `code`, `human_message`, `agent_instruction`, `action_required`, `handoff_skill`, `rerun_argv`, and `retryable`, plus per-code extras."""

const skill_calls_skill = """This skill never invokes the tfork skill itself. When a spawn is needed, send returns a `peer_unknown` handoff with `handoff_skill: \"tfork\"` and a pre-written `payload_file`; the calling agent invokes the tfork skill using whatever delayed-input mechanism that skill currently exposes (p2p does not prescribe a flag). Same rule in reverse: tfork never calls p2p."""
