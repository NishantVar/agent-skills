skill p2p(my_name = "" <"Stable short name this agent registers under on first use. Lowercase snake_case. Ignored on subsequent calls once a manifest exists.">, peer = "" <"Manifest name or cmux tab title of the destination peer. Manifest name beats tab title; tab title is fallback for first contact.">, message = "" <"Message body. Always passed via --message-file to side-step shell quoting.">)
    description: "P2P messaging between cmux agents: one verb (`send`) handles first contact, follow-up, and reply. Routes by per-surface manifest; returns a handoff JSON object when a peer must be spawned or another skill must run."

    require single_stable_name
    require always_use_send_verb
    require honor_handoff_json
    avoid skill_calls_skill

    flow:
        if inline_bootstrap_present.applies()
            reply_to_inline_bootstrap()
        else
            send_via_helper()

        if handoff_received.applies()
            follow_handoff_instruction()


block send_via_helper()
    description: "Issue one `send` call. The helper handles registration, peer resolution, plain-vs-bootstrap framing, cross-workspace routing, and payload-file generation."
    flow:
        "Write {message} to a temp file like `/tmp/p2p-out-{peer}.txt`."
        "Run `python3 ~/.claude/skills/p2p/agent_msg.py send --peer {peer} --message-file <path>`. Include `--my-name {my_name}` only on the first invocation in this agent's lifetime; the helper ignores it once a manifest exists."
        "Parse the JSON on stdout. `{ok: true}` is done. `{ok: false}` carries `code`, `agent_instruction`, and (per code) extra fields like `payload_file` or `candidates`."


block reply_to_inline_bootstrap()
    description: "An inbound `[p2p-bootstrap]` block is in this agent's prompt. Do one `send` call — register + reply in the same invocation."
    flow:
        "Read `peer_name=` / `peer_surface=` / `suggested_name=` from the inline `[p2p-bootstrap]` block in the user-turn prompt."
        "Write the reply body to a temp file like `/tmp/p2p-out-{peer}.txt`."
        "Run `python3 ~/.claude/skills/p2p/agent_msg.py send --peer <peer_name> --peer-surface <peer_surface> --bootstrap-suggested-name <suggested_name> --message-file <path>`. The helper registers this agent under `suggested_name` on the fly and routes directly without name/tab resolution."
        "If the bootstrap text is in a file rather than inline, pass `--bootstrap-file <path>` instead — it fills --peer, --peer-surface, and --bootstrap-suggested-name from the parsed text."


block follow_handoff_instruction()
    description: "The helper returned ok:false. Read `agent_instruction` and act."
    flow:
        "`peer_unknown` → invoke the tfork skill with `--delayed-input-file <payload_file> --delay 5`. The file is already written 0600; do not re-create it."
        "`peer_ambiguous` → pick a unique address (canonical manifest name, or one of `candidates[].ref`) and rerun send."
        "`info_needed` with `missing: [\"self_name\"]` → rerun with `--my-name <name>`."
        "`name_collision` / `name_collision_stale` → pick a different name and rerun."
        "`empty_message` → write a non-empty body and rerun."


const single_stable_name = """Pick one short, lowercase, snake_case name on the first call and keep it for life. Peers route by the manifest's `name` field; renaming mid-session makes this agent unreachable under the prior name."""

const always_use_send_verb = """All outgoing messages go through `agent_msg.py send`. Never call `cmux set-buffer`, `cmux paste-buffer`, or `cmux send-key` directly — the helper alone passes `--workspace` (without it cross-workspace delivery fails as `Surface is not a terminal`), applies the `[from: <me>]` prefix, and uses a per-op buffer name to avoid concurrent-sender interleaving."""

const honor_handoff_json = """When the helper returns `ok: false`, the JSON contains an explicit `agent_instruction` field. Follow it verbatim — do not improvise around it. The handoff carries `code`, `human_message`, `agent_instruction`, `action_required`, `handoff_skill`, `rerun_argv`, and `retryable`, plus per-code extras."""

const skill_calls_skill = """This skill never invokes the tfork skill itself. When a spawn is needed, send returns a `peer_unknown` handoff with `handoff_skill: \"tfork\"` and a pre-written `payload_file`; the calling agent invokes tfork with `--delayed-input-file <payload_file>`. Same rule in reverse: tfork never calls p2p."""
